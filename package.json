{
  "name": "node-tray",
  "version": "2.0.0",
  "description": "Another library for rendering a tray icon.",
  "keywords": [
    "napi",
    "native addon",
    "tray",
    "tray icon"
  ],
  "homepage": "https://github.com/s-h-a-d-o-w/node-tray.git",
  "license": "MIT",
  "author": "Andreas Opferkuch <andreas.opferkuch@gmail.com>",
  "files": [
    "dist",
    "binding.gyp",
    "src/tray.cpp",
    "src/tray.h"
  ],
  "type": "module",
  "main": "./dist/tray.js",
  "scripts": {
    "build": "rimraf dist && pnpm build:declaration && pnpm build:bundle",
    "build:bundle": "esbuild ./src/tray.ts --bundle --platform=node --target=node24 --format=esm --outfile=dist/tray.js",
    "build:declaration": "tsc -p tsconfig.prod.json",
    "dev": "node-gyp rebuild",
    "lint": "oxlint --report-unused-disable-directives-severity=error",
    "prepare": "husky",
    "prepack": "pnpm build",
    "start": "node ./example/index.ts",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^13.0.0"
  },
  "devDependencies": {
    "@types/bindings": "^1.5.5",
    "@types/node": "^24.13.2",
    "esbuild": "^0.24.0",
    "file-type": "^19.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "move-file-cli": "^3.0.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "rimraf": "^6.1.3",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "gypfile": true
}
